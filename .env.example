# ── Mistral AI ────────────────────────────────────────────────────────────────
# Get your key at https://console.mistral.ai/
# NEVER commit the real .env file — this file is a safe template only.
MISTRAL_API_KEY=your_mistral_api_key_here

# ── Database ───────────────────────────────────────────────────────────────────
# SQLite (default, zero setup):
DATABASE_URL=sqlite+aiosqlite:///./data/rag.db
# PostgreSQL (production swap — change this one line, nothing else changes):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/ragdb

# ── Vector store ───────────────────────────────────────────────────────────────
# Directory (relative to backend/) where numpy vectors are persisted
VECTOR_STORE_PATH=data/vectors

# ── Ingestion settings ────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=20
CHUNK_SIZE=500
CHUNK_OVERLAP=100

# ── Retrieval settings ────────────────────────────────────────────────────────
# Number of candidates fetched from each retriever before RRF fusion
RETRIEVAL_TOP_K=10
# Final chunks passed to the generator after re-ranking
RERANK_TOP_N=5
# Minimum similarity score — below this threshold we return "insufficient evidence"
SIMILARITY_THRESHOLD=0.35

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no wildcard in production)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
